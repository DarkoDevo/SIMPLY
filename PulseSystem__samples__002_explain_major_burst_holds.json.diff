+      "start_marker": "PULSE_UI_START: ACTION_CONST_DEATHKNIGHT_UNHOLY",
+      "end_marker": "PULSE_UI_END: ACTION_CONST_DEATHKNIGHT_UNHOLY",
+      "content": "            {\n                {\n                    E = \"Checkbox\",\n                    DB = \"HoldMajorBurstIntoWalls\",\n                    DBV = true,\n                    L = {\n                        enUS = \"Hold major burst into enemy walls\",\n                    },\n                    TT = {\n                        enUS = \"If enabled, major Unholy burst cooldowns are delayed while the enemy is inside broad defensive or immunity windows.\",\n                    },\n                    M = {},\n                },\n                {\n                    E = \"Slider\",\n                    MIN = -1,\n                    MAX = 100,\n                    DB = \"HoldMajorBurstEnemyHP\",\n                    DBV = 55,\n                    ONLYOFF = true,\n                    L = {\n                        ANY = \"Hold burst above enemy HP (%)\"\n                    },\n                    TT = {\n                        ANY = \"If the target is at or below this health, burst is allowed even if a broad defensive window is detected. Set -1 to always hold into detected walls.\"\n                    },\n                    M = {},\n                },\n                {\n                    E = \"Checkbox\",\n                    DB = \"PulseExplainBurstHolds\",\n                    DBV = true,\n                    L = {\n                        enUS = \"Show pulse messages for burst holds\",\n                    },\n                    TT = {\n                        enUS = \"Shows an on-screen Makulu message when major burst is being held because an enemy defensive or immunity window is detected.\",\n                    },\n                    M = {},\n                },\n                {\n                    E = \"Slider\",\n                    MIN = 1,\n                    MAX = 10,\n                    DB = \"PulseBurstHoldMessageThrottle\",\n                    DBV = 2,\n                    ONLYOFF = true,\n                    L = {\n                        ANY = \"Burst hold message throttle (sec)\"\n                    },\n                    TT = {\n                        ANY = \"Minimum time between repeated pulse burst-hold messages. Higher values reduce spam.\"\n                    },\n                    M = {},\n                },\n            },"
+    }
