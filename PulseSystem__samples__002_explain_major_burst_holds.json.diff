+{
+  "pulse_id": "002_explain_major_burst_holds",
+  "spec": "deathknight_unholy",
+  "summary": "Add pulse-driven awareness messages for held major burst windows, plus UI toggles to control message visibility and throttle.",
+  "operations": [
+    {
+      "type": "replace_between_markers",
+      "file": "Rotations/Deathknight/Deathknight_Unholy.lua",
+      "start_marker": "PULSE_RULES_START: ACTION_CONST_DEATHKNIGHT_UNHOLY_HELPERS",
+      "end_marker": "PULSE_RULES_END: ACTION_CONST_DEATHKNIGHT_UNHOLY_HELPERS",
+      "content": "local pulseRuntime = {\n    lastMajorBurstHoldMessageAt = 0,\n}\n\nlocal function PulseEnemyDefensiveWallActive(unitID)\n    if not Unit(unitID):IsExists() then\n        return false\n    end\n\n    return Unit(unitID):IsBuffUp(Full_Immune_Buffs)\n        or Unit(unitID):IsBuffUp(Phys_Immune_Buffs)\n        or Unit(unitID):IsBuffUp(Magic_Immune_Buffs)\n        or Unit(unitID):IsBuffUp(AMS_Bufftable)\nend\n\nlocal function PulseGetMajorBurstHoldReason(unitID)\n    if not Unit(unitID):IsExists() then\n        return nil\n    end\n\n    if Unit(unitID):IsBuffUp(Full_Immune_Buffs) then\n        return \"enemy immunity is active\"\n    end\n\n    if Unit(unitID):IsBuffUp(AMS_Bufftable) then\n        return \"anti-magic protection is active\"\n    end\n\n    if Unit(unitID):IsBuffUp(Phys_Immune_Buffs) or Unit(unitID):IsBuffUp(Magic_Immune_Buffs) then\n        return \"enemy defensive wall is active\"\n    end\n\n    return nil\nend\n\nlocal function PulseShouldHoldMajorBurst(unitID)\n    if not GetToggle(2, \"HoldMajorBurstIntoWalls\") then\n        return false\n    end\n\n    if not Unit(unitID):IsExists() then\n        return false\n    end\n\n    local hpGate = GetToggle(2, \"HoldMajorBurstEnemyHP\")\n    if hpGate ~= nil and hpGate >= 0 and Unit(unitID):HealthPercent() <= hpGate then\n        return false\n    end\n\n    return PulseEnemyDefensiveWallActive(unitID)\nend\n\nlocal function PulseShowMajorBurstHoldMessage(unitID)\n    if not GetToggle(2, \"PulseExplainBurstHolds\") then\n        return\n    end\n\n    if not PulseShouldHoldMajorBurst(unitID) then\n        return\n    end\n\n    if not Aware or not Aware.displayMessage then\n        return\n    end\n\n    local now = GetTime()\n    local throttle = GetToggle(2, \"PulseBurstHoldMessageThrottle\") or 2\n    if pulseRuntime.lastMajorBurstHoldMessageAt and (now - pulseRuntime.lastMajorBurstHoldMessageAt) < throttle then\n        return\n    end\n\n    local reason = PulseGetMajorBurstHoldReason(unitID) or \"enemy defensive window is active\"\n    local targetName = UnitName(unitID) or \"target\"\n    local message = string.format(\"Holding major burst on %s because %s.\", targetName, reason)\n    pulseRuntime.lastMajorBurstHoldMessageAt = now\n    Aware:displayMessage(message, \"DeathKnight\", throttle, GetSpellTexture(A.Apocalypse.ID), true)\nend"
+    },
