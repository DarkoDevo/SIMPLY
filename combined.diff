 -- PULSE_RULES_START: ACTION_CONST_DEATHKNIGHT_UNHOLY_HELPERS
+local function PulseEnemyDefensiveWallActive(unitID)
+    if not Unit(unitID):IsExists() then
+        return false
+    end
+
+    return Unit(unitID):IsBuffUp(Full_Immune_Buffs)
+        or Unit(unitID):IsBuffUp(Phys_Immune_Buffs)
+        or Unit(unitID):IsBuffUp(Magic_Immune_Buffs)
+        or Unit(unitID):IsBuffUp(AMS_Bufftable)
+end
+
+local function PulseShouldHoldMajorBurst(unitID)
+    if not GetToggle(2, "HoldMajorBurstIntoWalls") then
+        return false
+    end
+
+    if not Unit(unitID):IsExists() then
+        return false
+    end
+
+    local hpGate = GetToggle(2, "HoldMajorBurstEnemyHP")
+    if hpGate ~= nil and hpGate >= 0 and Unit(unitID):HealthPercent() <= hpGate then
+        return false
+    end
+
+    return PulseEnemyDefensiveWallActive(unitID)
+end
 -- PULSE_RULES_END: ACTION_CONST_DEATHKNIGHT_UNHOLY_HELPERS
